---
import { getCollection } from "astro:content";
import { withBase } from "../data/site.js";

const teamEntries = await getCollection("team");
const teamMembers = teamEntries.map((entry) => entry.data).sort((a, b) => a.order - b.order);
const groups = ["PI", "Postdoc", "PhD Student", "Master Student", "Visiting Student", "Research Assistant"];
const groupLabels: Record<string, string> = {
  PI: "PI",
  Postdoc: "Postdoc",
  "PhD Student": "PhD Students",
  "Master Student": "Master Students",
  "Visiting Student": "Visiting Students",
  "Research Assistant": "Research Assistants"
};
const initials = (name: string) => name.split(" ").map((part) => part[0]).join("");
const membersFor = (group: string) => teamMembers.filter((member) => member.role === group);
const groupSlug = (group: string) => group.toLowerCase().replaceAll(" ", "-");
const memberSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const profileLabel = (website: string) => {
  if (!website) return "Website pending";
  return website.includes("github.com") || website.includes("openreview.net") ? "Profile" : "Website";
};
---

<div class="team-directory">
  <div id="team-directory" class="team-groups">
  {groups.map((group) => (
    <section class={`team-group anchor-offset group-${groupSlug(group)}`} id={groupSlug(group)}>
      <div class="group-head">
        <h2>{groupLabels[group]}</h2>
        <span>{membersFor(group).length} people</span>
      </div>
      <div class={`member-grid ${membersFor(group).length === 1 ? "single" : ""}`}>
        {membersFor(group).map((member) => {
          const hasBio = Boolean(member.bio?.trim());

          return (
          <article
            class={`member-card ${group === "PI" ? "featured" : ""}`}
            id={`member-${memberSlug(member.name)}`}
            data-tags={member.researchTags.join("|")}
            tabindex="0"
            aria-expanded={hasBio ? "false" : undefined}
            aria-controls={hasBio ? `bio-${memberSlug(member.name)}` : undefined}
            data-has-bio={hasBio ? "true" : "false"}
          >
            <div class={`avatar ${member.photo ? "has-photo" : ""}`} aria-hidden={member.photo ? "false" : "true"}>
              {member.photo ? (
                <img
                  src={withBase(member.photo)}
                  alt={`${member.name} portrait`}
                  loading="lazy"
                  decoding="async"
                  style={`object-position: ${member.photoPosition ?? "50% 35%"}`}
                />
              ) : (
                <span>{initials(member.name)}</span>
              )}
            </div>
            <div class="member-copy">
              <h3>{member.name}</h3>
              <p class="role">{member.role}</p>
              {hasBio && <p class="member-summary">{member.bio}</p>}
              {hasBio && <p class="member-bio" id={`bio-${memberSlug(member.name)}`} hidden>{member.bio}</p>}
            </div>
            {member.website ? (
              <a class="profile-link" href={member.website} aria-label={`${member.name} ${profileLabel(member.website)}`}>
                <span>{profileLabel(member.website)}</span>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 17L17 7"></path>
                  <path d="M9 7h8v8"></path>
                  <path d="M17 17v3H4V7h3"></path>
                </svg>
              </a>
            ) : (
              <span class="profile-link disabled">Website pending</span>
            )}
          </article>
          );
        })}
      </div>
    </section>
  ))}
  </div>
</div>

<script>
  const members = Array.from(document.querySelectorAll("[data-tags]"));
  const toggleMember = (member: Element) => {
    if (!(member instanceof HTMLElement)) return;
    if (member.dataset.hasBio !== "true") return;
    const expanded = member.getAttribute("aria-expanded") === "true";
    member.setAttribute("aria-expanded", expanded ? "false" : "true");
    const bioId = member.getAttribute("aria-controls");
    const bio = bioId ? document.getElementById(bioId) : null;
    if (bio) bio.hidden = expanded;
  };

  members.forEach((member) => {
    member.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest("a")) return;
      toggleMember(member);
    });

    member.addEventListener("keydown", (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();
      toggleMember(member);
    });
  });
</script>

<style>
  .team-directory {
    display: grid;
    gap: 28px;
    margin: 0 auto;
    max-width: 1080px;
    min-width: 0;
  }

  .team-groups {
    display: grid;
    gap: 34px;
    grid-template-columns: 1fr;
    min-width: 0;
  }

  .team-group {
    --group-columns: 1;
    min-width: 0;
  }

  .group-pi,
  .group-postdoc {
    grid-column: 1 / -1;
  }

  .group-phd-student {
    grid-column: 1 / -1;
  }

  .group-visiting-student {
    grid-column: 1 / -1;
  }

  .group-research-assistant {
    grid-column: 1 / -1;
  }

  .group-head {
    align-items: baseline;
    display: flex;
    gap: 10px;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .group-head h2 {
    font-size: clamp(1.18rem, 1.6vw, 1.42rem);
  }

  .group-head span {
    color: var(--muted);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 750;
    text-transform: uppercase;
  }

  .member-grid {
    display: grid;
    gap: 12px;
    grid-auto-rows: 206px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 340px));
    justify-content: start;
    min-width: 0;
  }

  .member-grid.single {
    grid-template-columns: minmax(0, 340px);
  }

  .member-card {
    align-items: start;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    cursor: pointer;
    display: grid;
    gap: 12px;
    grid-template-columns: 102px minmax(0, 1fr);
    grid-template-rows: auto auto;
    height: 206px;
    max-height: 206px;
    min-height: 206px;
    overflow: hidden;
    padding: 14px;
    position: relative;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .member-card:hover,
  .member-card:focus-within,
  .member-card:target,
  .member-card[aria-expanded="true"] {
    border-color: rgba(0, 113, 227, 0.24);
    box-shadow: var(--shadow-hover);
    transform: translateY(-3px);
  }

  .member-card:target {
    outline: 3px solid rgba(0, 113, 227, 0.2);
    outline-offset: 4px;
  }

  .member-card:focus-visible {
    outline: 3px solid rgba(0, 113, 227, 0.52);
    outline-offset: 3px;
  }

  .member-card.featured {
    grid-column: span 1;
  }

  .avatar {
    align-items: center;
    aspect-ratio: 0.76;
    background:
      radial-gradient(circle at 50% 28%, rgba(255, 255, 255, 0.98) 0 16%, transparent 17%),
      radial-gradient(ellipse at 50% 84%, rgba(29, 29, 31, 0.12) 0 30%, transparent 31%),
      linear-gradient(180deg, #f9f9fb, #eeeeef);
    border: 1px solid var(--line);
    border-radius: 7px;
    display: flex;
    grid-row: 1;
    justify-content: center;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .avatar span {
    color: rgba(29, 29, 31, 0.58);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 900;
    transform: translateY(22px);
  }

  .avatar::after {
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.72), transparent);
    content: "";
    height: 1px;
    left: 12px;
    position: absolute;
    right: 12px;
    top: 74%;
  }

  .avatar.has-photo {
    background: #f5f5f7;
  }

  .avatar.has-photo img {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .avatar.has-photo::after {
    background: linear-gradient(180deg, transparent 58%, rgba(0, 0, 0, 0.12));
    height: auto;
    inset: 0;
    left: 0;
    right: 0;
    top: 0;
  }

  .member-copy {
    align-content: start;
    display: grid;
    gap: 8px;
    grid-row: 1;
    min-width: 0;
    overflow: hidden;
  }

  .member-copy h3 {
    font-size: 1.02rem;
    line-height: 1.05;
  }

  .member-copy p {
    font-size: 0.8rem;
    line-height: 1.44;
  }

  .member-summary {
    color: var(--muted);
    display: -webkit-box;
    line-clamp: 3;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .member-bio {
    background: #ffffff;
    border: 1px solid rgba(0, 113, 227, 0.18);
    border-radius: 7px;
    box-shadow: var(--shadow-hover);
    color: var(--muted);
    inset: 10px;
    margin: 0;
    overflow: auto;
    padding: 30px 10px 10px;
    position: absolute;
    z-index: 3;
  }

  .member-bio::before {
    color: var(--theorem);
    content: "Biography";
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 900;
    left: 10px;
    position: absolute;
    text-transform: uppercase;
    top: 8px;
  }

  .role,
  .affiliation {
    color: var(--muted);
  }

  .role {
    color: var(--theorem);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.15;
  }

  .profile-link {
    align-items: center;
    align-self: start;
    color: var(--theorem);
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 700;
    gap: 8px;
    grid-column: 1 / -1;
    justify-content: center;
    margin-top: 2px;
    min-height: 24px;
    text-decoration: none;
    white-space: nowrap;
  }

  .profile-link svg {
    fill: none;
    height: 17px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.2;
    width: 17px;
  }

  .profile-link.disabled {
    color: var(--muted);
    font-weight: 700;
  }

  .tag-list {
    gap: 5px;
    max-height: 48px;
    overflow: hidden;
  }

  .tag {
    font-size: 0.58rem;
    padding: 1px 5px;
  }

  @media (max-width: 1180px) {
    .team-groups {
      grid-template-columns: 1fr;
      row-gap: 30px;
    }

    .group-pi,
    .group-postdoc,
    .group-phd-student,
    .group-visiting-student,
    .group-research-assistant {
      --group-columns: 2;
      grid-column: 1 / -1;
    }

    .member-grid,
    .member-grid.single {
      grid-auto-rows: 206px;
      grid-template-columns: repeat(auto-fit, minmax(260px, 340px));
    }
  }

  @media (max-width: 760px) {
    .member-grid,
    .member-grid.single {
      grid-auto-rows: 206px;
      grid-template-columns: 1fr;
    }

    .member-card {
      height: 206px;
      grid-template-columns: 110px minmax(0, 1fr);
      max-height: 206px;
      min-height: 206px;
    }

    .avatar {
      width: 110px;
    }
  }

  @media (max-width: 520px) {
    .member-card {
      grid-template-columns: 100px minmax(0, 1fr);
      padding: 12px;
    }

    .avatar {
      width: 100px;
    }

    .member-copy h3 {
      font-size: 0.98rem;
    }

    .member-copy p {
      font-size: 0.8rem;
    }
  }
</style>
