---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, withBase } from "../data/site.js";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.mission } = Astro.props;
const pageTitle = title === site.name ? `${site.name} — ${site.fullName}` : `${title} — ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase("/logo.svg")} />
    <link rel="apple-touch-icon" href={withBase("/logo.png")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      document.documentElement.classList.add("reveal-ready");

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      const revealTargets = Array.from(document.querySelectorAll("[data-reveal]"));
      const revealAll = () => revealTargets.forEach((target) => target.classList.add("is-visible"));
      const revealFallback = window.setTimeout(revealAll, 700);
      const visibleRevealTargets = revealTargets.filter((target) => {
        if (!(target instanceof HTMLElement) || target.offsetParent !== null) return true;
        target.classList.add("is-visible");
        return false;
      });

      if (visibleRevealTargets.length > 0) {
        if (reducedMotion.matches || !("IntersectionObserver" in window)) {
          window.clearTimeout(revealFallback);
          revealAll();
        } else {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { rootMargin: "0px 0px 18% 0px", threshold: 0.05 }
          );

          visibleRevealTargets.forEach((target) => revealObserver.observe(target));
        }
      } else {
        window.clearTimeout(revealFallback);
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    background: var(--action);
    color: var(--ink);
    font-weight: 800;
    left: 16px;
    padding: 8px 12px;
    position: fixed;
    top: 12px;
    transform: translateY(-160%);
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0);
  }
</style>
