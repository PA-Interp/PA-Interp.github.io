---
import BaseLayout from "../layouts/BaseLayout.astro";
import TeamGrid from "../components/TeamGrid.astro";
import { withBase } from "../data/site.js";
---

<BaseLayout title="Team" description="PAI Lab team members and research community.">
  <section class="team-hero">
    <div class="container team-hero-grid">
      <div class="team-hero-copy">
        <span class="eyebrow">Our Team</span>
        <h1>People advancing provable, actionable interpretability.</h1>
        <p class="lead">Each member connects foundations, systems, interfaces, and applications around the PAI agenda.</p>
      </div>
      <div class="team-board" aria-hidden="true">
        <img
          class="board-image"
          src={withBase("/assets/team-research-map-whiteboard.png")}
          alt=""
          loading="eager"
          decoding="async"
        />
        <div class="board-surface">
          <svg class="board-map" viewBox="0 0 760 300" preserveAspectRatio="xMidYMid meet">
            <defs>
              <marker id="board-arrowhead" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
                <path d="M0,0 L8,4 L0,8 Z"></path>
              </marker>
            </defs>
            <g class="map-flow">
              <rect x="150" y="62" width="124" height="60" rx="7"></rect>
              <text x="212" y="84" text-anchor="middle">
                <tspan x="212" dy="0">Assumptions</tspan>
                <tspan x="212" dy="16">Guarantees</tspan>
                <tspan x="212" dy="16">Limits</tspan>
              </text>

              <rect x="320" y="58" width="96" height="56" rx="7"></rect>
              <text x="368" y="82" text-anchor="middle">
                <tspan x="368" dy="0">Model</tspan>
                <tspan x="368" dy="16">behavior</tspan>
              </text>

              <rect x="456" y="116" width="96" height="54" rx="7"></rect>
              <text x="504" y="139" text-anchor="middle">
                <tspan x="504" dy="0">Evidence</tspan>
                <tspan x="504" dy="16">tests</tspan>
              </text>

              <rect x="584" y="66" width="108" height="56" rx="7"></rect>
              <text x="638" y="90" text-anchor="middle">
                <tspan x="638" dy="0">Explanation</tspan>
                <tspan x="638" dy="16">map</tspan>
              </text>

              <rect x="552" y="210" width="76" height="48" rx="7"></rect>
              <text x="590" y="231" text-anchor="middle">
                <tspan x="590" dy="0">Human</tspan>
                <tspan x="590" dy="16">action</tspan>
              </text>

              <path d="M276 92 H308"></path>
              <path d="M416 86 C438 94 438 111 452 130"></path>
              <path d="M552 143 C575 130 590 117 610 122"></path>
              <path d="M606 208 C600 190 590 176 552 158"></path>
              <path class="map-loop" d="M476 174 C360 196 318 122 438 104"></path>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <section class="section compact team-directory-section">
    <div class="container">
      <TeamGrid />
    </div>
  </section>
</BaseLayout>

<style>
  .team-hero {
    overflow: hidden;
    padding: clamp(58px, 8vw, 92px) 0 34px;
    position: relative;
  }

  .team-hero-grid {
    min-height: 300px;
    position: relative;
    width: min(1080px, calc(100% - 40px));
    z-index: 4;
  }

  .team-hero-copy {
    align-content: center;
    display: grid;
    gap: 20px;
    max-width: 680px;
    min-height: 300px;
    min-width: 0;
    position: relative;
    width: min(56%, 680px);
    z-index: 4;
  }

  .team-hero h1 {
    font-size: clamp(3rem, 6.2vw, 5.45rem);
    line-height: 1;
    max-width: 680px;
    overflow-wrap: anywhere;
  }

  .team-hero .lead {
    font-size: 1.08rem;
    max-width: 620px;
  }

  .team-board {
    bottom: 0;
    min-height: 300px;
    overflow: hidden;
    position: absolute;
    right: 0;
    top: 0;
    width: 50vw;
  }

  .team-board::before {
    background:
      linear-gradient(90deg, rgba(245, 245, 247, 0.98), rgba(245, 245, 247, 0.72) 26%, rgba(245, 245, 247, 0.16) 62%),
      linear-gradient(180deg, rgba(245, 245, 247, 0.02), rgba(245, 245, 247, 0.48));
    content: "";
    inset: 0;
    position: absolute;
    z-index: 1;
  }

  .team-board::after {
    background: radial-gradient(circle at 42% 26%, rgba(0, 113, 227, 0.045), transparent 28%);
    content: "";
    inset: 0;
    position: absolute;
    z-index: 2;
  }

  .board-image {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
  }

  .board-surface {
    inset: 0;
    height: 100%;
    min-height: 300px;
    position: relative;
    z-index: 3;
  }

  .board-map {
    color: rgba(66, 66, 69, 0.58);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .board-map rect {
    fill: rgba(255, 255, 255, 0.3);
    stroke: rgba(0, 113, 227, 0.16);
    stroke-width: 1;
  }

  .board-map path {
    fill: none;
    marker-end: url("#board-arrowhead");
    stroke: rgba(0, 113, 227, 0.24);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.1;
  }

  .board-map marker path {
    fill: rgba(0, 113, 227, 0.3);
    stroke: none;
  }

  .board-map .map-loop {
    marker-end: none;
    stroke-dasharray: 5 5;
    stroke-width: 0.9;
  }

  .board-map text {
    fill: currentColor;
  }

  .team-directory-section :global(.container) {
    width: min(1080px, calc(100% - 40px));
  }

  @media (max-width: 980px) {
    .team-hero-copy {
      max-width: 100%;
      min-height: 0;
      width: 100%;
    }

    .team-board {
      border: 1px solid var(--line);
      border-radius: 8px;
      min-height: 320px;
      position: relative;
      width: 100%;
    }

    .team-hero-grid {
      display: grid;
      gap: 28px;
    }

    .team-board::before {
      background:
        linear-gradient(90deg, rgba(245, 245, 247, 0.44), rgba(245, 245, 247, 0.06)),
        linear-gradient(180deg, rgba(245, 245, 247, 0.02), rgba(245, 245, 247, 0.4));
    }
  }

  @media (max-width: 640px) {
    .team-hero {
      padding: 54px 0 24px;
    }

    .team-hero h1 {
      font-size: clamp(2.45rem, 12vw, 3.3rem);
      line-height: 1.02;
    }

    .team-board {
      min-height: 280px;
    }

    .board-surface {
      min-height: 280px;
    }

    .board-map {
      font-size: 9px;
      transform: scale(0.95);
      transform-origin: center;
    }

    .team-directory-section :global(.container) {
      width: min(1080px, calc(100% - 32px));
    }
  }
</style>
